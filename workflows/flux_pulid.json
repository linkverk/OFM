{
  "_comment": "Flux.1-dev Q5 GGUF + PuLID-Flux II + FaceDetailer + CodeFormer",
  "_comment_placeholders": "{{POSITIVE}}, {{NEGATIVE}}, {{FACE_IMAGE}}, {{WIDTH}}, {{HEIGHT}}, {{SEED}}, {{STEPS}}, {{GUIDANCE}}, {{PULID_WEIGHT}}, {{FLUX_UNET}}, {{CLIP_L}}, {{T5}}, {{VAE}}, {{PULID}}",
  "_note_clip": "DualCLIPLoader (не GGUF) — потому что T5 у нас t5xxl_fp8_e4m3fn.safetensors, а не GGUF. Для GGUF T5 (например t5-v1_1-xxl-Q5_K_M.gguf) надо ставить DualCLIPLoaderGGUF.",

  "1": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "{{FLUX_UNET}}"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "{{T5}}",
      "clip_name2": "{{CLIP_L}}",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "{{VAE}}"
    }
  },

  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{POSITIVE}}",
      "clip": ["2", 0]
    }
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE}}",
      "clip": ["2", 0]
    }
  },

  "20": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{FACE_IMAGE}}"
    }
  },
  "21": {
    "class_type": "PulidFluxModelLoader",
    "inputs": {
      "pulid_file": "{{PULID}}"
    }
  },
  "22": {
    "class_type": "PulidFluxEvaClipLoader",
    "inputs": {}
  },
  "23": {
    "class_type": "PulidFluxInsightFaceLoader",
    "inputs": {
      "provider": "CUDA"
    }
  },
  "24": {
    "class_type": "ApplyPulidFlux",
    "inputs": {
      "model": ["1", 0],
      "pulid_flux": ["21", 0],
      "eva_clip": ["22", 0],
      "face_analysis": ["23", 0],
      "image": ["20", 0],
      "weight": "{{PULID_WEIGHT}}",
      "start_at": 0.0,
      "end_at": 1.0
    }
  },

  "30": {
    "class_type": "FluxGuidance",
    "inputs": {
      "conditioning": ["10", 0],
      "guidance": "{{GUIDANCE}}"
    }
  },
  "31": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "batch_size": 1
    }
  },
  "32": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["24", 0],
      "positive": ["30", 0],
      "negative": ["11", 0],
      "latent_image": ["31", 0],
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "33": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["32", 0],
      "vae": ["3", 0]
    }
  },

  "40": {
    "class_type": "UltralyticsDetectorProvider",
    "inputs": {
      "model_name": "bbox/face_yolov8m.pt"
    }
  },
  "41": {
    "class_type": "FaceDetailer",
    "inputs": {
      "image": ["33", 0],
      "model": ["24", 0],
      "clip": ["2", 0],
      "vae": ["3", 0],
      "positive": ["30", 0],
      "negative": ["11", 0],
      "bbox_detector": ["40", 0],
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": "{{SEED}}",
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 0.4,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1
    }
  },

  "50": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["41", 0],
      "filename_prefix": "ai_ofm/character"
    }
  }
}