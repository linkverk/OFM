{
  "_comment": "Wan 2.2 I2V 14B Q4_K_M + Lightning 4+4 + SageAttention + BlockSwap 25 (без TeaCache — Lightning даёт основное ускорение)",
  "_uses": "ComfyUI-WanVideoWrapper by Kijai + ComfyUI-GGUF",
  "_placeholders": "{{WAN_HIGH}}, {{WAN_LOW}}, {{LIGHTNING_HIGH}}, {{LIGHTNING_LOW}}, {{WAN_VAE}}, {{WAN_T5}}, {{WAN_CLIP_VISION}}, {{START_IMAGE}}, {{POSITIVE}}, {{NEGATIVE}}, {{WIDTH}}, {{HEIGHT}}, {{FRAMES}}, {{SEED}}, {{BLOCKS_SWAP}}, {{STEPS_HIGH}}, {{STEPS_TOTAL}}",

  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "{{WAN_HIGH}}",
      "base_precision": "fp16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "compile_args": null,
      "block_swap_args": {
        "blocks_to_swap": "{{BLOCKS_SWAP}}",
        "offload_txt_emb": true,
        "offload_img_emb": true
      },
      "lora": null
    },
    "_note": "high-noise эксперт, используется на первой половине denoise"
  },
  "2": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "{{WAN_LOW}}",
      "base_precision": "fp16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "compile_args": null,
      "block_swap_args": {
        "blocks_to_swap": "{{BLOCKS_SWAP}}",
        "offload_txt_emb": true,
        "offload_img_emb": true
      },
      "lora": null
    }
  },

  "3": {
    "class_type": "WanVideoLoraSelect",
    "inputs": {
      "lora": "{{LIGHTNING_HIGH}}",
      "strength": 1.0,
      "merge_loras": false,
      "low_mem_load": false,
      "prev_lora": null
    },
    "_note_blocks": "Поле 'blocks' (SELECTEDBLOCKS) удалено — Kijai 998a69c+ падает на blocks=None в getlorapath:461. Для block-level LoRA tuning нужно добавить ноду WanVideoLoraBlockEdit. merge_loras=false обязательно (иначе WanVideoSetLoRAs отказывается mergить без low_mem_load)."
  },
  "4": {
    "class_type": "WanVideoLoraSelect",
    "inputs": {
      "lora": "{{LIGHTNING_LOW}}",
      "strength": 1.0,
      "merge_loras": false,
      "low_mem_load": false,
      "prev_lora": null
    }
  },

  "5": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "{{WAN_VAE}}",
      "precision": "fp16"
    }
  },
  "6": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "{{WAN_T5}}",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    },
    "_note_precision": "Свежий Kijai сузил precision до ['fp32','bf16']. Файл umt5_xxl_fp8_e4m3fn_scaled.safetensors уже хранится как fp8 — quantization=disabled оставляет его в fp8 на диске/в RAM, precision=bf16 — это compute precision на GPU."
  },
  "7": {
    "class_type": "LoadWanVideoClipTextEncoder",
    "inputs": {
      "model_name": "{{WAN_CLIP_VISION}}",
      "precision": "fp16",
      "load_device": "offload_device"
    }
  },

  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{START_IMAGE}}"
    }
  },
  "11": {
    "class_type": "WanVideoImageToVideoEncode",
    "inputs": {
      "start_image": ["10", 0],
      "vae": ["5", 0],
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "num_frames": "{{FRAMES}}",
      "noise_aug_strength": 0.0,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0,
      "force_offload": true,
      "clip_embeds": ["13", 0]
    },
    "_note_rename": "В свежем WanWrapper inputs.image переименован в start_image (и стал optional, т.к. появилась поддержка end_image и FLF2V/Fun control)."
  },
  "12": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "positive_prompt": "{{POSITIVE}}",
      "negative_prompt": "{{NEGATIVE}}",
      "t5": ["6", 0],
      "force_offload": true
    }
  },
  "13": {
    "class_type": "WanVideoClipVisionEncode",
    "inputs": {
      "clip_vision": ["7", 0],
      "image_1": ["10", 0],
      "strength_1": 1.0,
      "strength_2": 1.0,
      "crop": "center",
      "combine_embeds": "average",
      "force_offload": true
    },
    "_note_rename": "Свежий WanWrapper: inputs.image → image_1, плюс required strength_1/2, crop, combine_embeds, force_offload (для multi-image clip-vision; мы используем только image_1)."
  },

  "30": {
    "class_type": "WanVideoSetLoRAs",
    "inputs": {
      "model": ["1", 0],
      "lora": ["3", 0]
    },
    "_note_rename": "WanVideoLoraLoad заменён парой WanVideoLoraSelect (выбирает LoRA → WANVIDLORA) + WanVideoSetLoRAs (применяет к model). Цепочка нескольких LoRA — через prev_lora у LoraSelect."
  },
  "31": {
    "class_type": "WanVideoSetLoRAs",
    "inputs": {
      "model": ["2", 0],
      "lora": ["4", 0]
    }
  },

  "40": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["30", 0],
      "image_embeds": ["11", 0],
      "text_embeds": ["12", 0],
      "steps": "{{STEPS_HIGH}}",
      "cfg": 1.0,
      "shift": 5.0,
      "seed": "{{SEED}}",
      "scheduler": "lcm",
      "riflex_freq_index": 0,
      "force_offload": true,
      "denoise_strength": 1.0,
      "start_step": 0,
      "end_step": "{{STEPS_HIGH}}"
    },
    "_note": "стадия high-noise: 0 → STEPS_HIGH. riflex_freq_index=0 = RIFLEX выключен (родное поведение)."
  },
  "41": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["31", 0],
      "image_embeds": ["11", 0],
      "text_embeds": ["12", 0],
      "steps": "{{STEPS_TOTAL}}",
      "cfg": 1.0,
      "shift": 5.0,
      "seed": "{{SEED}}",
      "scheduler": "lcm",
      "riflex_freq_index": 0,
      "force_offload": true,
      "samples": ["40", 0],
      "denoise_strength": 1.0,
      "start_step": "{{STEPS_HIGH}}",
      "end_step": "{{STEPS_TOTAL}}"
    },
    "_note": "стадия low-noise: продолжает с latent от 40"
  },

  "50": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "samples": ["41", 0],
      "vae": ["5", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "60": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["50", 0],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "ai_ofm/i2v",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    },
    "_note_vhs": "crf/pix_fmt/save_metadata в свежем VHS убраны из API-входов — стали widget-only (хранятся в UI metadata, не в API payload). Применяются дефолты ffmpeg."
  }
}
