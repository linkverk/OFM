{
  "_comment": "Flux Kontext Dev Q5 GGUF — редактирует эталонный кадр по текстовому промпту",
  "_uses": "ComfyUI-GGUF + нативные ноды ComfyUI Kontext (в ядре с августа 2025)",
  "_placeholders": "{{KONTEXT_UNET}}, {{CLIP_L}}, {{T5}}, {{VAE}}, {{REF_IMAGE}}, {{EDIT_PROMPT}}, {{WIDTH}}, {{HEIGHT}}, {{STEPS}}, {{GUIDANCE}}, {{SEED}}",
  "_note_clip": "DualCLIPLoader (не GGUF) — т.к. T5 у нас .safetensors, не .gguf",

  "1": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "{{KONTEXT_UNET}}"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "{{T5}}",
      "clip_name2": "{{CLIP_L}}",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "{{VAE}}"
    }
  },

  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{REF_IMAGE}}"
    }
  },
  "11": {
    "class_type": "FluxKontextImageScale",
    "inputs": {
      "image": ["10", 0]
    },
    "_note": "Kontext-специфичный ресайз — важно для сохранения identity"
  },
  "12": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["11", 0],
      "vae": ["3", 0]
    }
  },

  "20": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{EDIT_PROMPT}}",
      "clip": ["2", 0]
    }
  },
  "21": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["2", 0]
    }
  },
  "22": {
    "class_type": "ReferenceLatent",
    "inputs": {
      "conditioning": ["20", 0],
      "latent": ["12", 0]
    },
    "_note": "ReferenceLatent = способ скормить эталон в conditioning Kontext'а"
  },
  "23": {
    "class_type": "FluxGuidance",
    "inputs": {
      "conditioning": ["22", 0],
      "guidance": "{{GUIDANCE}}"
    }
  },

  "30": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "batch_size": 1
    }
  },
  "31": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["23", 0],
      "negative": ["21", 0],
      "latent_image": ["30", 0],
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "beta",
      "denoise": 1.0
    }
  },
  "32": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["31", 0],
      "vae": ["3", 0]
    }
  },

  "40": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["32", 0],
      "filename_prefix": "ai_ofm/kontext"
    }
  }
}